{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniHub",
  "version": "1.0.1",
  "identifier": "com.percivalaletheos.omnihub",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OmniHub",
        "width": 1400,
        "height": 900,
        "minWidth": 820,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": false,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Percival Aletheos",
    "copyright": "© 2025 Percival Aletheos",
    "category": "Entertainment",
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": [
          "German"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "",
      "endpoints": [
        "https://github.com/P3rc1v4l/OmniHub/releases/latest/download/latest.json"
      ]
    }
  }
}